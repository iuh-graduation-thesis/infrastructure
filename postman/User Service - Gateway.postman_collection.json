  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token - Password Grant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "if (json.id_token) pm.collectionVariables.set('idToken', json.id_token);",
                  "pm.test('access token saved', () => pm.expect(pm.collectionVariables.get('accessToken')).to.not.be.empty);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloakUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
