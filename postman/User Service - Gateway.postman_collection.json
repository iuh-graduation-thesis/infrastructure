        "type": "text/javascript",
        "requests": {},
        "exec": [
          "if (!pm.collectionVariables.get('adminAuthorities')) {",
          "  pm.collectionVariables.set('adminAuthorities', 'USER_VIEW,USER_CREATE,ROLE_VIEW,ROLE_CREATE,ROLE_UPDATE,ROLE_DELETE,PERMISSION_VIEW,PERMISSION_CREATE,PERMISSION_UPDATE,PERMISSION_DELETE');",
          "}",
          "if (!pm.collectionVariables.get('roleName')) pm.collectionVariables.set('roleName', 'TEST_ROLE');",
          "if (!pm.collectionVariables.get('permissionName')) pm.collectionVariables.set('permissionName', 'TEST_PERMISSION');"
        ]
      }
