{
  "info": {
    "_postman_id": "0b4f2a54-6326-4c14-92de-user-gateway",
    "name": "User Service - Gateway",
    "description": "Call user-service endpoints through gateway. Base route: /user-service/**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('adminAuthorities')) {",
          "  pm.collectionVariables.set('adminAuthorities', 'USER_VIEW,USER_CREATE,ROLE_VIEW,ROLE_CREATE,ROLE_UPDATE,ROLE_DELETE,PERMISSION_VIEW,PERMISSION_CREATE,PERMISSION_UPDATE,PERMISSION_DELETE');",
          "}",
          "if (!pm.collectionVariables.get('roleName')) pm.collectionVariables.set('roleName', 'TEST_ROLE');",
          "if (!pm.collectionVariables.get('permissionName')) pm.collectionVariables.set('permissionName', 'TEST_PERMISSION');"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/user-service" },
    { "key": "keycloakUrl", "value": "http://localhost:9000" },
    { "key": "realm", "value": "graduation-thesis" },
    { "key": "clientId", "value": "graduation-thesis-id" },
    { "key": "clientSecret", "value": "" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "admin" },
    { "key": "scope", "value": "openid profile email" },
    { "key": "accessToken", "value": "" },
    { "key": "keycloakId", "value": "" },
    { "key": "userEmail", "value": "admin@example.com" },
    { "key": "roleId", "value": "" },
    { "key": "permissionId", "value": "" },
    { "key": "roleName", "value": "TEST_ROLE" },
    { "key": "permissionName", "value": "TEST_PERMISSION" },
    { "key": "adminAuthorities", "value": "USER_VIEW,USER_CREATE,ROLE_VIEW,ROLE_CREATE,ROLE_UPDATE,ROLE_DELETE,PERMISSION_VIEW,PERMISSION_CREATE,PERMISSION_UPDATE,PERMISSION_DELETE" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token - Password Grant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('accessToken', json.access_token);",
                  "if (json.id_token) pm.collectionVariables.set('idToken', json.id_token);",
                  "pm.test('access token saved', () => pm.expect(pm.collectionVariables.get('accessToken')).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{clientId}}", "type": "text" },
                { "key": "client_secret", "value": "{{clientSecret}}", "type": "text" },
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" },
                { "key": "scope", "value": "{{scope}}", "type": "text" }
              ]
            },
            "url": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Onboarding Me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"Tester\",\n  \"phone\": \"0901234567\",\n  \"dob\": \"2000-01-01\",\n  \"gender\": \"MALE\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/users/me/onboarding"
          }
        },
        {
          "name": "Get User Permissions - Internal",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/internal/users/{{keycloakId}}/permissions"
          }
        }
      ]
    },
    {
      "name": "Admin Roles",
      "item": [
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{roleName}}\",\n  \"description\": \"Temporary role from Postman\",\n  \"permissionIdList\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/admin/roles"
          }
        },
        {
          "name": "List Roles - Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const roles = body.result?.result || body.result || [];",
                  "const target = roles.find(r => r.name === pm.collectionVariables.get('roleName')) || roles.find(r => r.name === 'ADMIN') || roles[0];",
                  "if (target?.id) pm.collectionVariables.set('roleId', target.id);",
                  "pm.test('roleId saved when roles exist', () => pm.expect(pm.collectionVariables.get('roleId')).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/roles?page=0&size=10"
          }
        },
        {
          "name": "List Roles - All",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const roles = Array.isArray(body.result) ? body.result : [];",
                  "const target = roles.find(r => r.name === pm.collectionVariables.get('roleName')) || roles.find(r => r.name === 'ADMIN') || roles[0];",
                  "if (target?.id) pm.collectionVariables.set('roleId', target.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/roles/all"
          }
        },
        {
          "name": "Get Role By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Update Role By ID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{roleName}}\",\n  \"description\": \"Updated from Postman\",\n  \"permissionIdList\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/admin/roles/{{roleId}}"
          }
        },
        {
          "name": "Delete Role By ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/admin/roles/{{roleId}}"
          }
        }
      ]
    },
    {
      "name": "Admin Permissions",
      "item": [
        {
          "name": "Create Permission",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{permissionName}}\",\n  \"description\": \"Temporary permission from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/admin/permissions"
          }
        },
        {
          "name": "List Permissions - Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const permissions = body.result?.result || body.result || [];",
                  "const target = permissions.find(p => p.name === pm.collectionVariables.get('permissionName')) || permissions[0];",
                  "if (target?.id) pm.collectionVariables.set('permissionId', target.id);",
                  "pm.test('permissionId saved when permissions exist', () => pm.expect(pm.collectionVariables.get('permissionId')).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/permissions?page=0&size=10"
          }
        },
        {
          "name": "List Permissions - All",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const permissions = Array.isArray(body.result) ? body.result : [];",
                  "const target = permissions.find(p => p.name === pm.collectionVariables.get('permissionName')) || permissions[0];",
                  "if (target?.id) pm.collectionVariables.set('permissionId', target.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/permissions/all"
          }
        },
        {
          "name": "Update Permission By ID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{permissionName}}\",\n  \"description\": \"Updated from Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/admin/permissions/{{permissionId}}"
          }
        },
        {
          "name": "Delete Permission By ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/admin/permissions/{{permissionId}}"
          }
        }
      ]
    }
  ]
}
